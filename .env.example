GIT_REPO_URL=
GIT_REF=
ENABLE_GIT_SYNC_ON_BOOT=1
TARGET_STACK_ROOT=/opt/minecraft
TARGET_ENV_COMMAND=
TARGET_ENV_FILE=
STACK_NAME=mc-paper-velocity-geyser-stack

GOOGLE_DRIVE_REMOTE=homelab-gdrive
RESTIC_REPOSITORY=rclone:homelab-gdrive:minecraft/mc-paper-velocity-geyser-stack
RESTIC_PASSWORD_FILE=/opt/minecraft-backup-google-drive/secrets/restic-password
RESTIC_CACHE_DIR=runtime/restic-cache
RCLONE_CONFIG=

LOG_DIR=logs
RUNTIME_DIR=runtime
STAGING_DIR=staging

OFFSITE_KEEP_HOURLY=24
OFFSITE_KEEP_DAILY=14
OFFSITE_KEEP_WEEKLY=8
OFFSITE_KEEP_MONTHLY=6
OFFSITE_BACKUP_TAGS=minecraft offsite

OFFSITE_TIMER_ON_CALENDAR=*:0/30
LOCAL_TIMER_ON_CALENDAR=*-*-* 03:30:00
VERIFY_TIMER_ON_CALENDAR=*-*-* 04:15:00
VERIFY_OFFSITE_SNAPSHOT=1
VERIFY_SCOPE=survival
VERIFY_CONFIG_ASSETS=1
SERVER_NOTIFICATIONS_ENABLED=1

DOCKER_BIN=docker
RESTIC_BIN=restic
RCLONE_BIN=rclone
SNAPSHOT_SLEEP_SECONDS=5
# Add new required variables below as needed. Update this file when new variables are added to the stack.
